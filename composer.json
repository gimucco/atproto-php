{
    "name": "gimucco/atproto-php",
    "description": "AT Protocol OAuth 2.1 client for PHP — PKCE, DPoP, and PAR support for authenticating with Bluesky and other atproto services.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "keywords": ["atproto", "bluesky", "oauth", "dpop", "pkce", "par"],
    "homepage": "https://github.com/gimucco/atproto-php",
    "authors": [
        {
            "name": "Gimucco",
            "email": "info@gimucco.com",
            "role": "Maintainer"
        },
        {
            "name": "Andrea Olivato",
            "email": "andrea@olivato.me",
            "role": "Developer"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "ext-curl": "*",
        "ext-openssl": "*",
        "ext-sodium": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "psr/log": "^3.0",
        "web-token/jwt-library": "^3.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.11",
        "phpstan/phpstan-strict-rules": "^1.6",
        "friendsofphp/php-cs-fixer": "^3.50",
        "guzzlehttp/guzzle": "^7.8",
        "guzzlehttp/psr7": "^2.6"
    },
    "suggest": {
        "guzzlehttp/guzzle": "Recommended PSR-18 HTTP client (used in the examples)"
    },
    "autoload": {
        "psr-4": {
            "Gimucco\\Atproto\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gimucco\\Atproto\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/generate-metadata"],
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "phpstan": "phpstan analyse",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": false
        }
    }
}
